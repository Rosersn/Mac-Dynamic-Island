          }
        }
      }
    },
    "%@:": {
      "comment": "A row of text with a label and its corresponding value. The argument is the label text, and the second is the value text.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "pt-BR": {
          "stringUnit": {
