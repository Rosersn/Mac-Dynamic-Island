    "Clear clipboard history removes recent copies. Clear pinned items removes your favorites. Both actions are permanent.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Durch „Zwischenablage löschen“ werden die letzten Kopien entfernt. Durch „Angeheftete Elemente löschen“ werden Ihre Favoriten entfernt. Beide Aktionen sind dauerhaft."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Effacer l’historique du presse-papier supprime les copies récentes. Effacer les éléments épinglés supprime vos favoris. Les deux actions sont permanentes."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
