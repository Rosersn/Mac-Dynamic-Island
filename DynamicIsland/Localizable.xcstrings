    "Are you sure you want to delete \"%@\"?": {
      "comment": "A confirmation prompt asking the user to confirm the deletion of a custom idle animation. The placeholder text inside the quotation marks should be replaced with the name of the animation.",
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Voulez-vous vraiment supprimer \"%@\" ?"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Tem certeza de que deseja excluir “%@”?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "确定要删除“%@”吗？"
          }
        }
      }
    },
    "Are you sure you want to delete this color from your history?": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Voulez-vous vraiment supprimer cette couleur de votre historique ?"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Tem certeza de que deseja excluir essa cor do seu histórico?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "确定要从历史记录中删除此颜色吗？"
