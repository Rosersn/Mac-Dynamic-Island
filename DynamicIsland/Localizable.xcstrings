    "Notchi": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Notchi"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Notchi"
          }
        }
      },
      "shouldTranslate": false
    },
    "Notchi can show all your upcoming events in one place. Access to your calendar is needed to display your schedule.": {
      "localizations": {
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Notchi pode mostrar todos os seus próximos eventos em um só lugar. O acesso ao seu calendário é necessário para exibir sua agenda."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Notchi 可在一处显示所有即将到来的事件，需要访问日历以显示日程。"
          }
        }
      }
    },
    "Notchi includes a mirror feature that lets you quickly check your appearance using your camera, right from the notch. Camera access is required only to show this live preview. You can turn the mirror feature on or off at any time in the app.": {
      "localizations": {
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Notchi possui um recurso de espelho que permite verificar rapidamente sua aparência usando sua câmera, direto do notch. O acesso à câmera é necessário apenas para mostrar esta visualização ao vivo. Você pode ligar ou desligar o recurso de espelho a qualquer momento no aplicativo."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Notchi 包含镜像功能，可直接从刘海使用摄像头快速检查外观。摄像头访问仅用于显示实时预览，可随时在应用中开关镜像功能。"
          }
        }
      }
    },
    "Notchi needs Full Disk Access to read the system notification database. If Notchi does not appear in the list, use 'Reveal App in Finder' and drag it into the settings window.": {
      "extractionState": "stale",
      "localizations": {
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Notchi precisa de Acesso Completo ao Disco para ler o banco de dados de notificações do sistema. Se o Notchi não aparecer na lista, use ‘Mostrar aplicativo no Finder' e arraste-o para a janela de configurações."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Notchi 需要完全磁盘访问权限以读取系统通知数据库。如果 Notchi 未出现在列表中，请使用“在 Finder 中显示应用”并将其拖入设置窗口。"
          }
        }
      }
    },
