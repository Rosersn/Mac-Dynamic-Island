        }
      }
    },
    "Ask me anything...": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Demandez-moi ce que vous voulez…"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Me pergunte qualquer coisa…"
          }
