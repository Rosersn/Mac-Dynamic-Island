    "Displays a HUD notification when Bluetooth audio devices (headphones, AirPods, speakers) connect, showing device name and battery level.": {
      "comment": "A footer for the \"Bluetooth Audio Devices\" section in the HUD settings.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Affiche une notification sur l’ATH lorsque des appareils audio Bluetooth (Écouteurs, AirPods, enceintes) se connectent, et affiche le nom et la charge de la batterie de celui-ci."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Exibe uma notificação HUD quando os dispositivos de áudio Bluetooth (fones de ouvido, AirPods, alto-falantes) se conectam, mostrando o nome do dispositivo e o nível da bateria."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "蓝牙音频设备（耳机、AirPods、扬声器）连接时显示 HUD 通知，显示设备名称和电量。"
          }
        }
      }
    },
    "Displays play/pause and skip buttons beside the notch while music is active. Disabled by default.": {
      "localizations": {
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Exibe os botões de reprodução/pausa e pular ao lado do notch enquanto a música está ativa. Desativado por padrão."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "音乐播放时在刘海旁显示播放/暂停和跳过按钮，默认禁用。"
          }
        }
      }
    },
    "Displays the current Focus state above the weather capsule whenever Focus detection is enabled.": {
      "localizations": {
        "pt-BR": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Exibe o estado atual do Foco acima da cápsula climática sempre que a detecção de Foco está ativada."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "启用专注检测时，在天气胶囊上方显示当前专注状态。"
          }
        }
      }
    },
    "Displays your next upcoming calendar event above or below the weather capsule. Calendar selection here is independent from the Dynamic Island calendar filter.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在天气胶囊上方或下方显示下一个日历事件，此处的日历选择与灵动岛日历筛选器无关。"
          }
        }
      }
    },
