    "%@ Offset": {
      "comment": "A control within the lock screen settings that allows the user to adjust the offset for a specific dimension (e.g. width or height). The argument is the name of the dimension, and the second argument is",
      "isCommentAutoGenerated": true,
      "localizations": {
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ Deslocamento"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 偏移"
          }
        }
      }
    },
    "%@ pt": {
      "comment": "A text view displaying the current offset value for a specific lock screen control. The argument is the name of the control.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ pt"
          }
