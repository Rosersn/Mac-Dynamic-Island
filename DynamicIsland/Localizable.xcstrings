    },
    "Your camera is never used without your consent, and nothing is recorded or stored.": {
      "localizations": {
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sua câmera nunca é usada sem o seu consentimento, e nada é gravado ou armazenado."
