        }
      }
    },
    "%@. Focus active: %@": {
      "comment": "A row that combines a calendar event with a focus indicator. The first argument is the text of the calendar event. The second argument is the name of the focus.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@. Focus active: %2$@"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@。专注激活：%@"
          }
        }
      }
    },
    "%@°": {
