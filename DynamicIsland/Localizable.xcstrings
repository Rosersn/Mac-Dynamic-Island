          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将刘海风格视差效果应用于锁屏媒体小组件的专辑封面。"
          }
        }
      }
    },
    "Apps using AtollExtensionKit will appear here once they request permission": {
      "comment": "A description below the placeholder text in the \"Search extensions...\" text field, explaining that apps using AtollExtensionKit will be listed here once they grant permission to use the app.",
      "isCommentAutoGenerated": true,
      "localizations": {
