            "value": "Controles"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "控制中心"
          }
        }
      }
    },
    "Controls how often system metrics refresh while monitoring is active.": {
      "localizations": {
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Controla com que frequência as métricas do sistema são atualizadas enquanto o monitoramento está ativo."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "控制监控活跃时系统指标的刷新频率。"
          }
        }
      }
    },
    "Controls the lock screen reminder chip and its positioning.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "控制锁屏提醒芯片及其位置。"
          }
        }
      }
    },
    "Controls the optional timer widget that floats above the media panel, including its classic, frosted, or liquid glass surface independent of the global material setting.": {
      "localizations": {
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Controla o widget de temporizador opcional que flutua acima do painel de mídia, incluindo sua superfície de vidro clássico, fosco ou líquido, independentemente da configuração global do material."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "控制浮动在媒体面板上方的可选计时器小组件，包括独立于全局材质设置的表面样式。"
          }
        }
      }
    },
    "Controls whether Dynamic Island mirrors lock/unlock events with its own live activity and audible chimes.": {
      "localizations": {
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Controla se a Dynamic Island espelha eventos de bloqueio/desbloqueio com sua própria atividade ao vivo e sinos audíveis."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "控制灵动岛是否通过自己的实时动态和提示音镜像锁定/解锁事件。"
          }
        }
      }
